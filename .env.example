# ─── API Authentication ───────────────────────────────────────────────────────
API_KEY=maim12345

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_WINDOW_MS=60000
RATE_LIMIT=30

# ─── Proxy (Optional) ─────────────────────────────────────────────────────────
# Examples: http://user:pass@host:8080  |  socks5://127.0.0.1:1080
PROXY_URL=no proxy

# ─── Request Timeout (ms) ─────────────────────────────────────────────────────
REQUEST_TIMEOUT=60000

# ─── CORS extra origins (comma-separated) ─────────────────────────────────────
ALLOWED_ORIGINS=
